rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Photobooks: Publicly readable, admin only write
    match /photobooks/{bookId} {
      allow read: if true;
      allow write: if isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Orders: Private to owner, system can update status
    match /orders/{orderId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid 
                   && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    // Users: Private to owner
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Admins helper collection
    match /admins/{userId} {
      allow read: if isSignedIn();
    }
  }
}
